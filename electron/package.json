{
  "name": "novel-copilot-desktop",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "dist/main.mjs",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "build": "node scripts/build.mjs",
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@google/genai": "^0.14.0",
    "@hono/node-server": "^1.14.0",
    "@mariozechner/pi-ai": "^0.54.0",
    "@sinclair/typebox": "^0.34.48",
    "archiver": "^7.0.1",
    "better-sqlite3": "^11.8.1",
    "dotenv": "^16.4.5",
    "electron-store": "^10.0.0",
    "hono": "4.11.0",
    "jszip": "^3.10.1",
    "openai": "^6.10.0",
    "partial-json": "^0.1.7",
    "undici": "^7.22.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@electron/asar": "^4.2.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.2",
    "electron": "^35.2.1",
    "electron-builder": "^26.0.12",
    "esbuild": "^0.25.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  },
  "build": {
    "appId": "com.novelcopilot.desktop",
    "productName": "Novel Copilot",
    "icon": "build/icon.png",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "renderer/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../src/db",
        "to": "db",
        "filter": [
          "**/*.sql"
        ]
      },
      {
        "from": "../migrations",
        "to": "migrations",
        "filter": [
          "**/*.sql"
        ]
      }
    ],
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "build/icon.icns",
      "category": "public.app-category.productivity"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
